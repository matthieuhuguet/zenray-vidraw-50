#!/usr/bin/env python3
"""
Bande-son BGM = 8 fichiers dans un ordre fixe, BOUCLES sur la duree exacte de la video.
Derniere occurrence rognee pour tomber pile. Chaque fichier a deja fade in/out 1s + pic -12 dBFS.
Sortie : "Interview BGM Loop.wav".
"""
import os, re, subprocess

DEST = "/Users/zenray/Downloads/DJI/16 Juin 2026/BestOf/Videos/InterviewPablo"
SRC  = f"{DEST}/BGM/LoopTracks"           # pistes sources triees (NN - Titre.wav)
VIDEO = f"{DEST}/DJI_20000609125435_0264_D.MP4"
SEGDIR = "/tmp/bgm_loop"
SR = 48000

# Tableau simple = ordre de lecture de la boucle. Ajoute des lignes pour
# plus de variete (ex. video 1h55). Les fichiers vivent dans SRC.
ORDER = [
    "01 - Psycho-Pass OST ： A World of Contradictions.wav",
    "02 - A Journey (A Dream of Flight).wav",
    "03 - Nahoko (An Unexpected Meeting).wav",
    "04 - A Shooting Star.wav",
    "05 - slow summer eve.wav",
    "06 - Reze.wav",
    "07 - Sal Blossoms.wav",
    "08 - The Beginning.wav",
]

def dur(p):
    return float(subprocess.run(["ffprobe","-v","error","-show_entries","format=duration",
        "-of","csv=p=0",p],capture_output=True,text=True).stdout.strip())

def reformat(src,out):
    subprocess.run(["ffmpeg","-y","-i",src,"-ar",str(SR),"-ac","2","-c:a","pcm_s24le",out],
                   check=True,capture_output=True)

def trim_seg(src,out,L):
    # garde le fade-in existant, ajoute un fade-out 1s au nouveau bout
    af=f"afade=t=out:st={L-1:.3f}:d=1"
    subprocess.run(["ffmpeg","-y","-t",f"{L:.3f}","-i",src,"-af",af,
                    "-ar",str(SR),"-ac","2","-c:a","pcm_s24le",out],check=True,capture_output=True)

def fmt(s):
    return f"{int(s//60):02d}:{s%60:06.3f}"

def main():
    os.makedirs(SEGDIR,exist_ok=True)
    for f in os.listdir(SEGDIR): os.remove(f"{SEGDIR}/{f}")
    T=dur(VIDEO)
    durs={n:dur(f"{SRC}/{n}") for n in ORDER}

    seq=[]; acc=0.0; i=0
    while acc < T-0.001:
        name=ORDER[i%len(ORDER)]
        d=durs[name]
        if acc+d <= T+0.0005:
            seq.append((name,d,False)); acc+=d
        else:
            seq.append((name,T-acc,True)); acc=T; break
        i+=1

    print(f"Video={T:.3f}s  cycle={sum(durs.values()):.3f}s  segments={len(seq)}\n")
    seg_files=[]; t=0.0
    for k,(name,L,trim) in enumerate(seq):
        out=f"{SEGDIR}/{k:02d}.wav"
        if trim: trim_seg(f"{SRC}/{name}",out,L)
        else:    reformat(f"{SRC}/{name}",out)
        print(f"  {fmt(t)}  {L:7.3f}s  {name}{'  [ROGNE]' if trim else ''}")
        t+=L; seg_files.append(out)

    listf=f"{SEGDIR}/list.txt"
    open(listf,"w").write("".join(f"file '{s}'\n" for s in seg_files))
    out_final=f"{DEST}/Interview BGM Loop.wav"
    subprocess.run(["ffmpeg","-y","-f","concat","-safe","0","-i",listf,"-c","copy",out_final],
                   check=True,capture_output=True)
    print(f"\nFINAL={dur(out_final):.3f}s  cible={T:.3f}s  ecart={dur(out_final)-T:+.3f}s")
    print(f"-> {out_final}")

if __name__=="__main__":
    main()
