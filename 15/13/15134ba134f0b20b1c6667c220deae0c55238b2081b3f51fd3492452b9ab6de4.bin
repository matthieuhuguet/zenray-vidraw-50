#!/usr/bin/env python3
"""
Construit la bande-son BGM EXACTEMENT a la duree de la video.
Ordre : Psycho-Pass (1er) -> pistes kensuke ushio (Reze Arc OST, ordre album) -> A Shooting Star (dernier).
Chaque segment : fade in 1s + fade out 1s + pic -12 dBFS. Derniere piste de remplissage rognee pour tomber pile.
Concatenation -> "Interview BGM Bed.wav".
"""
import os, re, subprocess, json

DEST = "/Users/zenray/Downloads/DJI/16 Juin 2026/BestOf/Videos/InterviewPablo"
ALB  = "/Users/zenray/Downloads/Chainsaw Man the Movie Reze Arc Original Soundtrack [MP3]"
VIDEO = f"{DEST}/DJI_20000609125435_0264_D.MP4"
SEGDIR = "/tmp/bgm_segments"
SR = 48000
FADE = 1.0
TARGET_DB = -12.0

def dur(path):
    out = subprocess.run(["ffprobe","-v","error","-show_entries","format=duration",
                          "-of","csv=p=0",path],capture_output=True,text=True).stdout.strip()
    return float(out)

def maxvol(path):
    p = subprocess.run(["ffmpeg","-i",path,"-af","volumedetect","-f","null","-"],
                       capture_output=True,text=True)
    m = re.search(r"max_volume:\s*(-?\d+(?:\.\d+)?)\s*dB", p.stderr)
    return float(m.group(1)) if m else 0.0

def render(src, out, seg_len, do_norm=True):
    """Rend un segment de longueur seg_len (rogne si < duree source), 48k/24/stereo,
    fade in/out 1s, pic -12 dBFS si do_norm."""
    chain = []
    fo = seg_len - FADE
    chain.append(f"afade=t=in:st=0:d={FADE}")
    chain.append(f"afade=t=out:st={fo:.3f}:d={FADE}")
    if do_norm:
        gain = TARGET_DB - maxvol(src)
        chain.append(f"volume={gain:.2f}dB")
    af = ",".join(chain)
    subprocess.run(["ffmpeg","-y","-t",f"{seg_len:.3f}","-i",src,"-af",af,
                    "-ar",str(SR),"-ac","2","-c:a","pcm_s24le",out],
                   check=True,capture_output=True)

def reformat(src, out):
    """Copie un wav deja traite (fades+norm) en format concat-compatible, SANS re-fader."""
    subprocess.run(["ffmpeg","-y","-i",src,"-ar",str(SR),"-ac","2",
                    "-c:a","pcm_s24le",out],check=True,capture_output=True)

def main():
    os.makedirs(SEGDIR, exist_ok=True)
    for f in os.listdir(SEGDIR): os.remove(f"{SEGDIR}/{f}")

    T = dur(VIDEO)
    psycho = f"{DEST}/Psycho-Pass OST ： A World of Contradictions.wav"
    star   = f"{DEST}/A Shooting Star.wav"
    d_psycho, d_star = dur(psycho), dur(star)
    fill_target = T - d_psycho - d_star
    print(f"Video={T:.3f}s  Psycho={d_psycho:.3f}  Star={d_star:.3f}  fill_target={fill_target:.3f}")

    # pistes album dans l'ordre (kensuke ushio), exclure pistes purement SFX/voix si besoin
    album = sorted([f for f in os.listdir(ALB) if f.lower().endswith(".mp3")],
                   key=lambda x: int(re.match(r"(\d+)", x).group(1)))
    # exclure la piste 12 (titre japonais, courte interlude voix) optionnel : on la garde, c'est kensuke ushio

    # selection : accumuler jusqu'a fill_target, rogner la derniere
    chosen, acc = [], 0.0
    last_trim = None
    for name in album:
        p = f"{ALB}/{name}"
        dd = dur(p)
        if acc + dd < fill_target - 0.5:
            chosen.append((p, dd)); acc += dd
        else:
            last_trim = (p, fill_target - acc)  # rogne pour tomber pile
            break
    if last_trim is None:
        raise SystemExit("album trop court pour remplir")

    # plan
    plan = [("Psycho-Pass", psycho, d_psycho, False)]
    for p, dd in chosen:
        plan.append((os.path.basename(p), p, dd, True))
    p, tl = last_trim
    plan.append((os.path.basename(p)+f" [rogne {tl:.1f}s]", p, tl, True))
    plan.append(("A Shooting Star", star, d_star, False))

    print(f"\n{len(plan)} segments :")
    total = 0.0
    seg_files = []
    for i,(label,src,seg_len,norm) in enumerate(plan):
        out = f"{SEGDIR}/{i:02d}.wav"
        if not norm and abs(seg_len - dur(src)) < 0.05:
            reformat(src, out)          # deja fade+norm (Psycho, Star)
        else:
            render(src, out, seg_len, do_norm=norm)
        dseg = dur(out)
        total += dseg
        seg_files.append(out)
        print(f"  {i:02d}  {dseg:7.3f}s  {label}")

    # concat
    listf = f"{SEGDIR}/list.txt"
    with open(listf,"w") as fh:
        for s in seg_files:
            fh.write(f"file '{s}'\n")
    out_final = f"{DEST}/Interview BGM Bed.wav"
    subprocess.run(["ffmpeg","-y","-f","concat","-safe","0","-i",listf,
                    "-c","copy",out_final],check=True,capture_output=True)
    final = dur(out_final)
    print(f"\nTOTAL segments={total:.3f}s  | concat final={final:.3f}s  | cible={T:.3f}s  | ecart={final-T:+.3f}s")
    print(f"-> {out_final}")

if __name__ == "__main__":
    main()
